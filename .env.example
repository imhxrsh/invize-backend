# Copy to .env and adjust. Prisma / MongoDB
# With docker-compose.yml: single-node replica set rs0 (Prisma requires a replica set for transactions).
# Install Compose V2: sudo apt-get install -y docker-compose-plugin  →  docker compose version
# Start DB: ./scripts/compose.sh up -d   (or: bun run db:up)
# If only root/sudo can use Docker: export INVIZE_USE_SUDO_DOCKER=1  (or: sudo usermod -aG docker "$USER" && newgrp docker)
# After first up: cd backend && ./venv/bin/prisma db push && ./venv/bin/prisma generate
MONGO_URI=mongodb://127.0.0.1:27017/invize?replicaSet=rs0&directConnection=true
# Backend running inside Compose (same network as mongo): use host mongo:27017 and omit directConnection:
# MONGO_URI=mongodb://mongo:27017/invize?replicaSet=rs0

# Auth (change JWT_SECRET in any shared environment)
JWT_SECRET=change-me-in-production
# Next.js dev proxies /api/auth/* — cookie Path must match browser requests (default).
REFRESH_COOKIE_PATH=/api/auth
# If the browser calls the API origin directly (e.g. http://127.0.0.1:8000/auth/*), use:
# REFRESH_COOKIE_PATH=/auth

# Optional: Swarms / LLM (document pipeline analysis + GET /agent/hello)
GROQ_API_KEY=
AGENT_MODEL_NAME=openai/gpt-oss-20b
# Optional: document field fill when regex misses totals (processor step)
GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
# Optional: payment agent suggestions on Payments Hub
GROQ_PAYMENT_AGENT_MODEL=llama-3.3-70b-versatile
ANALYSIS_CONTEXT=Context7

# OCR (host binaries required: tesseract-ocr, poppler-utils for pdf2image)
TESSERACT_LANGS=eng
PSM_DEFAULT=6
PDF_DPI=300

# Heavy optional extractor (GPU/torch); default regex-only extraction
USE_LAYOUTLM=false
# USE_LAYOUTLM=true
# LAYOUTLM_DEVICE=cpu

# Server
API_HOST=127.0.0.1
API_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO

# CORS (comma-separated). Required when the browser uses NEXT_PUBLIC_BACKEND_URL / NEXT_PUBLIC_API_BASE_URL
# (calls API from another host). Example production:
# CORS_ALLOW_ORIGINS=https://invize.harshdev.site
# CORS_ALLOW_ORIGINS=http://localhost:3000

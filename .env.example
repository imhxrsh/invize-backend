# Invize Backend - Example Environment
#
# Copy to .env and adjust. Prisma / MongoDB: single-node replica set rs0 (Prisma needs a replica set for transactions).
# With docker-compose: ./scripts/compose.sh up -d (or bun run db:up), then from backend/.venv:
#   PATH=".venv/bin:$PATH" prisma generate && PATH=".venv/bin:$PATH" prisma db push
# (PATH needed so the prisma-client-py generator binary is found.)
# Local MongoDB example below; inside Compose use host mongo:27017 and omit directConnection if appropriate.

# Server
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
LOG_LEVEL=info
APP_ENV=development
SERVICE_VERSION=0.1.0

# MongoDB connection (Prisma + Motor)
MONGO_URI=mongodb://127.0.0.1:27017/invize?replicaSet=rs0&directConnection=true
# MONGO_URI=mongodb://mongo:27017/invize?replicaSet=rs0

# JWT settings
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
JWT_ISSUER=invize-backend
JWT_AUDIENCE=invize-client

# Refresh token transport: "cookie" or "header"
REFRESH_TOKEN_TRANSPORT=cookie

# Next.js dev often proxies /api/auth/* — cookie Path must match browser requests.
REFRESH_COOKIE_PATH=/api/auth
# If the browser calls the API origin directly (e.g. http://127.0.0.1:8000/auth/*), use:
# REFRESH_COOKIE_PATH=/auth

# CORS: comma-separated list of allowed origins for frontend
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Swarms Agent
# Groq Cloud API key (do not commit real keys)
GROQ_API_KEY=

# Swarms / hello-agent model id (Groq OpenAI-compatible). For production prefer larger models:
#   - llama-3.3-70b-versatile  (strong JSON + reasoning; recommended default)
#   - llama-3.1-8b-instant     (faster, cheaper; more JSON mistakes)
#   - openai/gpt-oss-20b       (legacy default in code; ok for dev)
AGENT_MODEL_NAME=llama-3.3-70b-versatile

# If Swarms returns non-JSON once, retry with a stricter one-shot prompt (default: true).
AGENT_JSON_RETRY=true

# Optional: document field fill when regex misses; payment agent; analysis
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
# GROQ_PAYMENT_AGENT_MODEL=llama-3.3-70b-versatile
# ANALYSIS_CONTEXT=Context7

# --------------------------------------------
# Document Intelligence Agent Configuration
# --------------------------------------------
# Redis connection for job status/result storage
REDIS_URL=redis://127.0.0.1:6379/0

# File processing limits
MAX_FILE_SIZE_MB=50
# Note: supported formats are defined in code and include: pdf,png,jpg,jpeg,tiff,tif,txt

# OCR configuration (host: tesseract-ocr, poppler-utils for pdf2image)
TESSERACT_LANGS=eng
PSM_DEFAULT=6
OEM_DEFAULT=3

# PDF processing
PDF_DPI=300

# LayoutLM configuration
USE_LAYOUTLM=false
LAYOUTLM_MODEL=microsoft/layoutlmv3-base
LAYOUTLM_DEVICE=auto
LAYOUTLM_TASK=token-classification
LAYOUTLM_CONFIDENCE_THRESHOLD=0.5

# --------------------------------------------
# Verification & Compliance Agent
# --------------------------------------------
USE_VERIFICATION_AGENT=true
DUPLICATE_CHECK_ENABLED=true
DUPLICATE_INVOICE_NUMBER_THRESHOLD=85
DUPLICATE_HASH_MAX_DISTANCE=10
DUPLICATE_LOOKBACK_DAYS=365
AUTHENTICITY_QUALITY_ENABLED=true
AUTHENTICITY_BLUR_THRESHOLD=100
AUTHENTICITY_QUALITY_MIN_SCORE=0.3
AUDIT_LOG_ENABLED=true
AUDIT_LOG_TO_DB=true
# AUDIT_LOG_FILE=  # optional; defaults to agent_workspace/audit/audit.log

# --------------------------------------------
# Matching & ERP Agent (demo; Tally/SAP later)
# --------------------------------------------
USE_MATCHING_ERP_AGENT=true
MATCHING_ENABLED=true
MATCH_3_WAY_ENABLED=true
MATCH_VARIANCE_TOLERANCE_PERCENT=0
ERP_TYPE=demo
# ERP_BASE_URL=
# ERP_API_KEY=
# ERP_TIMEOUT=30
# ERP_POST_INVOICE_ENABLED=false

# --------------------------------------------
# Operations & Workflow Agent
# --------------------------------------------
USE_OPERATIONS_WORKFLOW_AGENT=true
APPROVAL_ENABLED=true
DEFAULT_SLA_HOURS=72
WORKFLOW_REMINDERS_ENABLED=false
# Optional: override queue name per exception type, e.g. EXCEPTION_QUEUE_no_po=no_po_review

# --------------------------------------------
# Gmail inbox scan (OAuth redirect must match Google Cloud console)
# --------------------------------------------
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/gmail/oauth/callback
GMAIL_OAUTH_FRONTEND_SUCCESS_URL=http://localhost:3000/dashboard/settings?tab=integrations&gmail=connected
# Optional Fernet key for token encryption; if unset, derived from JWT_SECRET
# GMAIL_TOKEN_FERNET_KEY=
GMAIL_SCAN_MAX_MESSAGES=25
# invoice,receipt → download first PDF/image attachment and run document pipeline
GMAIL_PIPELINE_CATEGORIES=invoice,receipt
GMAIL_PIPELINE_MAX_ATTACHMENT_MB=50
